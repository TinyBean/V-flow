# V-flow 环境变量配置
# 用法:cp .env.example .env,填入真实值后 docker compose up 即生效。
# .env 已被 .gitignore 忽略,不会被提交;.env.example 作为模板纳入版本。
# 留空 OPENLIST_USER(或 OPENLIST_DAV)则网盘功能关闭。

# ---- 网盘(经 OpenList WebDAV 桥接 115 / 夸克)----

# OpenList 的 WebDAV 根地址(含 /dav 路径)
OPENLIST_DAV=http://192.168.31.223:5244/dav

# OpenList 账号(留空 = 关闭网盘功能)
OPENLIST_USER=

# OpenList 密码
OPENLIST_PASS=

# V-flow 里网盘挂载的虚拟目录名(一般不用改)
NET_PREFIX=net
